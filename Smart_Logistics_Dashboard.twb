      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0w63i410j921tl13wew4b0c7mdme].[avg:Delay_Probability:qk]&quot;' value='Predicted Delay %' />
          <alias key='&quot;[federated.0w63i410j921tl13wew4b0c7mdme].[avg:Logistics_Delay:qk]&quot;' value='Actual Delay %' />
        </aliases>
      </column>
      <column caption='Asset ID' datatype='string' name='[Asset_ID]' role='dimension' type='nominal' />
      <column caption='Asset Utilization' datatype='real' name='[Asset_Utilization]' role='measure' type='quantitative' />
      <column caption='Delay Percentage' datatype='real' name='[Calculation_1725512031369310209]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Logistics_Delay]) / COUNT([Logistics_Delay])' />
      </column>
      <column caption='Inventory Category' datatype='string' name='[Calculation_1725512031369474050]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Inventory_Level] &lt; 200 THEN &quot;Low operational load&quot;&#10;ELSEIF [Inventory_Level] &lt;= 400 THEN &quot;Balanced operational load&quot;&#10;ELSE &quot;High operational load&quot;&#10;END' />
      </column>
      <column caption='On Time Shipments' datatype='integer' name='[Calculation_1725512031370256388]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Logistics_Delay]) - SUM([Logistics_Delay])' />
      </column>
      <column caption='Total Delays' datatype='integer' name='[Calculation_1725512031370424325]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Logistics_Delay])' />
      </column>
      <column caption='Total Shipments' datatype='integer' name='[Calculation_1725512031370481670]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Logistics_Delay])' />
      </column>
      <column caption='Delay Performance Category' datatype='string' name='[Calculation_1939503384230338560]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Logistics_Delay]) &gt; WINDOW_AVG(SUM([Logistics_Delay]))&#10;THEN &quot;Above Avg&quot;&#10;ELSE &quot;Below Avg&quot;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Min(1)' datatype='integer' name='[Calculation_2363123224894951425]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='Min(1)' />
      </column>
      <column caption='On Time Rate' datatype='real' name='[Calculation_2363123224900677634]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1725512031370256388] / [Calculation_1725512031370481670]' />
      </column>
      <column caption='Calculation1' datatype='string' name='[Calculation_2865274585042841600]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1725512031369310209] &gt; 0.5 THEN &quot;🔴 Critical&quot;&#10;ELSEIF [Calculation_1725512031369310209] &gt; 0.4 THEN &quot;🟠 Warning&quot;&#10;ELSE &quot;🟢 Stable&quot;&#10;END' />
      </column>
      <column caption='Target' datatype='real' name='[Calculation_2903555181881925632]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0.40' />
      </column>
      <column caption='variance' datatype='real' name='[Calculation_2903555181882028033]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1725512031369310209]-[Calculation_2903555181881925632]' />
      </column>
      <column caption='varaiance kpi arrow' datatype='string' name='[Calculation_2903555181885100034]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2903555181882028033] &gt; 0 THEN&#10;&quot;▲+&quot; + STR(ROUND([Calculation_2903555181882028033]*100,1)) + &quot;%&quot;&#10;ELSE&#10;&quot;▼ &quot; + STR(ROUND([Calculation_2903555181882028033]*100,1)) + &quot;%&quot;&#10;END' />
      </column>
      <column caption='Predictioin Error' datatype='real' name='[Calculation_3025363478119436288]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([Delay_Probability]) - AVG([Logistics_Delay]))' />
      </column>
      <column caption='Peak Hour Flag' datatype='string' name='[Calculation_3047388895068921857]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1725512031369310209] &gt; WINDOW_AVG([Calculation_1725512031369310209])&#10;THEN &quot;Peak&quot;&#10;ELSE &quot;Normal&quot;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Peak Band' datatype='real' name='[Calculation_3047388895069122562]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1725512031369310209] &gt; WINDOW_AVG([Calculation_1725512031369310209])&#10;THEN [Calculation_1725512031369310209]&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Delay Probability' datatype='real' name='[Delay_Probability]' role='measure' type='quantitative' />
      <column caption='Demand Forecast' datatype='integer' name='[Demand_Forecast]' role='measure' type='quantitative' />
